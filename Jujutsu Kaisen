-- Kiểm tra và tải thư viện Rayfield an toàn
local success, Rayfield = pcall(function()
    return loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
end)

if not success or not Rayfield then
    warn("Không thể tải thư viện Rayfield! Hãy kiểm tra lại executor của bạn.")
    return
end

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local player = Players.LocalPlayer

local Config = {
	HitboxEnabled = false,
	TeleportEnabled = false,
	AutoClickEnabled = false,
	AutoSkillEnabled = false,
	SelectedTarget = "Tất cả (Gần nhất)"
}

local activeHitboxes = {}
local previousTarget = nil

local function showKillNotification(targetName)
	pcall(function()
		Rayfield:Notify({
			Title = "HẠ GỤC THÀNH CÔNG!",
			Content = "Bạn đã tiễn " .. targetName .. " lên bảng đếm số!",
			Duration = 3,
			Image = 4483362458,
		})
	end)
end

local Window = Rayfield:CreateWindow({
	Name = "JJS Menu - Safe Version",
	LoadingTitle = "Đang tải hệ thống...",
	LoadingSubtitle = "Nguồn Tamdz",
	ConfigurationSaving = { Enabled = false },
	KeySystem = false,
})

local MainTab = Window:CreateTab("Tính năng chính", 4483362458)
local TargetTab = Window:CreateTab("Chọn Mục tiêu", 4483362458)

-- ==================== HÀM HITBOX ====================
local function removeAllHitboxes()
	for _, data in pairs(activeHitboxes) do
		if data and data.Hitbox then data.Hitbox:Destroy() end
	end
	activeHitboxes = {}
end

local function applyHitboxToEnemy(otherPlayer)
	if otherPlayer == player then return end
	local function setup(character)
		if not Config.HitboxEnabled then return end
		local humanoidRootPart = character:WaitForChild("HumanoidRootPart", 5)
		if not humanoidRootPart or character:FindFirstChild("EnemyBigHitbox") then return end

		local bigHitbox = Instance.new("Part")
		bigHitbox.Name = "EnemyBigHitbox"
		bigHitbox.Size = humanoidRootPart.Size * 50
		bigHitbox.CFrame = humanoidRootPart.CFrame
		bigHitbox.Transparency = 0.9
		bigHitbox.CanCollide = false
		bigHitbox.CanTouch = true
		bigHitbox.Massless = true
		bigHitbox.Parent = character

		local weld = Instance.new("WeldConstraint")
		weld.Part0 = humanoidRootPart
		weld.Part1 = bigHitbox
		weld.Parent = bigHitbox

		activeHitboxes[otherPlayer] = {Hitbox = bigHitbox, Char = character}
	end
	if otherPlayer.Character then setup(otherPlayer.Character) end
	otherPlayer.CharacterAdded:Connect(setup)
end

-- ==================== HÀM LẤY DANH SÁCH PLAYER ====================
local function getPlayerList()
	local list = {"Tất cả (Gần nhất)", "🎯 Thấp máu nhất (Ưu tiên)"}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player then
			table.insert(list, p.Name .. " (" .. p.DisplayName .. ")")
		end
	end
	return list
end

local targetDropdown

local function getTarget()
	local myChar = player.Character
	if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
	local myHRP = myChar.HumanoidRootPart

	if Config.SelectedTarget == "🎯 Thấp máu nhất (Ưu tiên)" then
		local lowestHpPlayer = nil
		local minHealth = math.huge
		
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local hum = p.Character:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 and hum.Health < minHealth then
					minHealth = hum.Health
					lowestHpPlayer = p
				end
			end
		end
		if lowestHpPlayer then return lowestHpPlayer end
	elseif Config.SelectedTarget ~= "Tất cả (Gần nhất)" then
		for _, p in ipairs(Players:GetPlayers()) do
			local identifier = p.Name .. " (" .. p.DisplayName .. ")"
			if identifier == Config.SelectedTarget or p.Name == Config.SelectedTarget then
				if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
					local hum = p.Character:FindFirstChildOfClass("Humanoid")
					if hum and hum.Health > 0 then return p end
				end
			end
		end
	end
	
	local closestPlayer = nil
	local shortestDistance = math.huge
	
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			local enemyHum = p.Character:FindFirstChildOfClass("Humanoid")
			if enemyHum and enemyHum.Health > 0 then
				local dist = (myHRP.Position - p.Character.HumanoidRootPart.Position).Magnitude
				if dist < shortestDistance then
					shortestDistance = dist
					closestPlayer = p
				end
			end
		end
	end
	return closestPlayer
end

local function pressKey(keyCode)
	pcall(function()
		VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
		task.wait(0.05)
		VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
	end)
end

-- ==================== GIAO DIỆN RAYFIELD ====================

targetDropdown = TargetTab:CreateDropdown({
	Name = "Chọn Mục Tiêu / Săn Máu Thấp",
	Options = getPlayerList(),
	CurrentOption = "Tất cả (Gần nhất)",
	Flag = "TargetDropdown",
	Callback = function(Option)
		Config.SelectedTarget = Option
	end,
})

TargetTab:CreateButton({
	Name = "Làm mới danh sách Player",
	Callback = function()
		targetDropdown:Refresh(getPlayerList(), true)
	end,
})

MainTab:CreateToggle({
	Name = "Hitbox 50x Kẻ Địch",
	CurrentValue = false,
	Flag = "HitboxToggle",
	Callback = function(Value)
		Config.HitboxEnabled = Value
		if Value then
			for _, p in ipairs(Players:GetPlayers()) do applyHitboxToEnemy(p) end
		else
			removeAllHitboxes()
		end
	end,
})

MainTab:CreateToggle({
	Name = "Auto Teleport (Bám sát mục tiêu)",
	CurrentValue = false,
	Flag = "TpToggle",
	Callback = function(Value) Config.TeleportEnabled = Value end,
})

MainTab:CreateToggle({
	Name = "Auto Đánh Thường (M1 Click)",
	CurrentValue = false,
	Flag = "AutoClickToggle",
	Callback = function(Value) Config.AutoClickEnabled = Value end,
})

MainTab:CreateToggle({
	Name = "Auto Dùng Skill (1, 2, 3, 4)",
	CurrentValue = false,
	Flag = "AutoSkillToggle",
	Callback = function(Value) Config.AutoSkillEnabled = Value end,
})

-- ==================== VÒNG LẶP XỬ LÝ CHÍNH ====================

local skillTick = 0

RunService.RenderStepped:Connect(function()
	pcall(function()
		if Config.HitboxEnabled then
			for otherPlayer, data in pairs(activeHitboxes) do
				if data.Hitbox and data.Char and data.Char:FindFirstChild("HumanoidRootPart") then
					data.Hitbox.CFrame = data.Char.HumanoidRootPart.CFrame
				else
					activeHitboxes[otherPlayer] = nil
				end
			end
		end

		local target = getTarget()
		
		if previousTarget and previousTarget.Character then
			local hum = previousTarget.Character:FindFirstChildOfClass("Humanoid")
			if not hum or hum.Health <= 0 then
				showKillNotification(previousTarget.Name)
				previousTarget = nil
			elseif target ~= previousTarget and target ~= nil then
				if hum.Health <= 5 then
					showKillNotification(previousTarget.Name)
				end
				previousTarget = target
			end
		else
			previousTarget = target
		end

		local myChar = player.Character
		if target and target.Character and myChar then
			local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
			local myHRP = myChar:FindFirstChild("HumanoidRootPart")
			
			if targetHRP and myHRP then
				if Config.TeleportEnabled then
					myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 1.5)
					if myHRP:IsA("BasePart") then
						myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
					end
				end

				myHRP.CFrame = CFrame.new(myHRP.Position, targetHRP.Position)

				if Config.AutoClickEnabled then
					VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
					task.wait(0.01)
					VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
				end

				if Config.AutoSkillEnabled then
					skillTick = skillTick + 1
					if skillTick > 40 then
						skillTick = 0
						local skills = {Enum.KeyCode.One, Enum.KeyCode.Two, Enum.KeyCode.Three, Enum.KeyCode.Four}
						pressKey(skills[math.random(1, #skills)])
					end
				end
			end
		end
	end)
end)

Players.PlayerAdded:Connect(function(p)
	if Config.HitboxEnabled then applyHitboxToEnemy(p) end
end)

Rayfield:LoadConfiguration()
