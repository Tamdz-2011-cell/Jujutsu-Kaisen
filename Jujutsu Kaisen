-- ==================== HÀM HITBOX ====================
local function removeAllHitboxes()
	for _, data in pairs(activeHitboxes) do
		if data and data.Hitbox then data.Hitbox:Destroy() end
	end
	activeHitboxes = {}
end

local function applyHitboxToEnemy(otherPlayer)
	if otherPlayer == player then return end
	local function setup(character)
		if not Config.HitboxEnabled then return end
		local humanoidRootPart = character:WaitForChild("HumanoidRootPart", 5)
		if not humanoidRootPart or character:FindFirstChild("EnemyBigHitbox") then return end

		local bigHitbox = Instance.new("Part")
		bigHitbox.Name = "EnemyBigHitbox"
		bigHitbox.Size = humanoidRootPart.Size * 50
		bigHitbox.CFrame = humanoidRootPart.CFrame
		bigHitbox.Transparency = 0.9
		bigHitbox.CanCollide = false
		bigHitbox.CanTouch = true
		bigHitbox.Massless = true
		bigHitbox.Parent = character

		local weld = Instance.new("WeldConstraint")
		weld.Part0 = humanoidRootPart
		weld.Part1 = bigHitbox
		weld.Parent = bigHitbox

		activeHitboxes[otherPlayer] = {Hitbox = bigHitbox, Char = character}

		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			local diedConn
			diedConn = humanoid.Died:Connect(function()
				if bigHitbox then bigHitbox:Destroy() end
				if diedConn then diedConn:Disconnect() end
			end)
		end
	end
	if otherPlayer.Character then setup(otherPlayer.Character) end
	otherPlayer.CharacterAdded:Connect(setup)
end

-- ==================== HÀM LẤY DANH SÁCH PLAYER ====================
local function getPlayerList()
	local list = {"Tất cả (Gần nhất)", "🎯 Thấp máu nhất (Ưu tiên)"}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player then
			local identifier = p.Name .. " (" .. p.DisplayName .. ")"
			table.insert(list, identifier)
		end
	end
	return list
end

local targetDropdown

-- ==================== HÀM KIỂM TRA LÃNH ĐỊA AN TOÀN ====================
local function isSelfInDomain(char)
	if not char then return false end
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if humanoid and (char:FindFirstChild("Stun") or char:FindFirstChild("Action")) then
		return true
	end
	return false
end

-- ==================== HÀM TÌM MỤC TIÊU ====================
local function getTarget()
	local myChar = player.Character
	if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
	local myHRP = myChar.HumanoidRootPart

	local inDomain = isSelfInDomain(myChar)

	if inDomain then
		local closestInDomain = nil
		local minDistance = 60
		
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local enemyHum = p.Character:FindFirstChildOfClass("Humanoid")
				if enemyHum and enemyHum.Health > 0 then
					local dist = (myHRP.Position - p.Character.HumanoidRootPart.Position).Magnitude
					if dist < minDistance then
						minDistance = dist
						closestInDomain = p
					end
				end
			end
		end
		
		if closestInDomain then 
			return closestInDomain 
		else 
			goto normalSearch
		end
	end

	::normalSearch::

	if Config.SelectedTarget == "🎯 Thấp máu nhất (Ưu tiên)" then
		local lowestHpPlayer = nil
		local minHealth = math.huge
		
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local hum = p.Character:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 and hum.Health < minHealth then
					minHealth = hum.Health
					lowestHpPlayer = p
				end
			end
		end
		if lowestHpPlayer then return lowestHpPlayer end
	elseif Config.SelectedTarget ~= "Tất cả (Gần nhất)" then
		for _, p in ipairs(Players:GetPlayers()) do
			local identifier = p.Name .. " (" .. p.DisplayName .. ")"
			if identifier == Config.SelectedTarget or p.Name == Config.SelectedTarget then
				if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
					local hum = p.Character:FindFirstChildOfClass("Humanoid")
					if hum and hum.Health > 0 then return p end
				end
			end
		end
	end
	
	local closestPlayer = nil
	local shortestDistance = math.huge
	
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			local enemyHum = p.Character:FindFirstChildOfClass("Humanoid")
			if enemyHum and enemyHum.Health > 0 then
				local dist = (myHRP.Position - p.Character.HumanoidRootPart.Position).Magnitude
				if dist < shortestDistance then
					shortestDistance = dist
					closestPlayer = p
				end
			end
		end
	end
	return closestPlayer
end

local function pressKey(keyCode)
	pcall(function()
		VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
		task.wait(0.05)
		VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
	end)
end

